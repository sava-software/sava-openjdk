# Ignore everything by default; only explicitly track what is needed.
/*

# Build instructions
!/Dockerfile

# Ignore/exclude rules themselves
!/.dockerignore
!/.gitignore

# Project metadata
!/README.md

# Tracked configuration directories
!/.github
#!/.junie

!/scripts

# Release Please configuration and manifest
!/release-please-config.json
!/.release-please-manifest.json

!LICENSE
